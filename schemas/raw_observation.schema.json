{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thsi.local/schemas/raw_observation.schema.json",
  "title": "THSI Raw Personal Observation",
  "description": "Schema for raw or semi-raw personal signal observations before baseline comparison and graph node mapping.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observation_id",
    "subject_id",
    "timestamp",
    "signal_type",
    "value",
    "unit",
    "source",
    "quality_score",
    "context",
    "notes"
  ],
  "properties": {
    "observation_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this raw observation record."
    },
    "subject_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier for the person to whom the observation applies."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime when the observation was recorded."
    },
    "signal_type": {
      "type": "string",
      "enum": [
        "heart_rate",
        "resting_heart_rate",
        "hrv_rmssd",
        "hrv_sdnn",
        "sleep_duration",
        "sleep_efficiency",
        "sleep_fragmentation",
        "eda",
        "skin_conductance_response",
        "salivary_cortisol",
        "activity_level",
        "steps",
        "subjective_stress",
        "subjective_energy",
        "subjective_mood",
        "caffeine_intake",
        "medication_change",
        "illness_symptoms",
        "recent_exercise"
      ],
      "description": "Type of physiological or contextual signal measured."
    },
    "value": {
      "description": "Observed value: boolean, number, string, or structured object."
    },
    "unit": {
      "type": ["string", "null"],
      "description": "Measurement unit when applicable; null otherwise."
    },
    "source": {
      "type": "string",
      "enum": [
        "wearable",
        "manual_input",
        "lab_test",
        "derived_feature",
        "questionnaire",
        "unknown"
      ]
    },
    "quality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Observation quality weight between 0 and 1."
    },
    "context": {
      "type": "object",
      "description": "Structured contextual metadata for conservative interpretation."
    },
    "notes": {
      "type": "string",
      "description": "Free-text notes about the observation."
    }
  }
}

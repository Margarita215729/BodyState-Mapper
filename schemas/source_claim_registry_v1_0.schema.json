{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thsi.local/schemas/source_claim_registry_v1_0.schema.json",
  "title": "THSI Source-Claim Registry v1.0",
  "description": "Explicit, reviewable mapping from evidence sources to the curated graph nodes and edges they support. Claim text is verbatim from curated source metadata and is never invented. An empty source_claims array is permitted only as an initial scaffold.",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "source_claims"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "registry_id",
        "version",
        "claim_text_policy",
        "total_sources",
        "total_claims"
      ],
      "properties": {
        "registry_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "scientific_name": { "type": "string" },
        "product": { "type": "string" },
        "not_a_diagnostic_system": { "type": "boolean" },
        "build_timestamp": { "type": "string" },
        "generated_by": { "type": "string" },
        "sources_of_truth": { "type": "array", "items": { "type": "string" } },
        "claim_text_policy": { "type": "string", "minLength": 1 },
        "total_sources": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "source_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "claims", "supported_node_ids", "supported_edge_ids"],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "title": { "type": "string" },
          "claims": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "claim_count": { "type": "integer", "minimum": 0 },
          "supported_node_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "supported_edge_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "evidence_strength_score": {
            "oneOf": [
              { "type": "integer", "minimum": 1, "maximum": 5 },
              { "type": "null" }
            ]
          },
          "risk_of_overinterpretation": {
            "oneOf": [
              { "type": "string", "enum": ["low", "medium", "high", "critical"] },
              { "type": "null" }
            ]
          },
          "claim_text_source": { "type": "string" },
          "linkage_granularity": {
            "type": "string",
            "enum": ["source_level", "claim_level"]
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thsi.local/schemas/static_graph.schema.json",
  "title": "THSI Static Scientific Evidence Graph",
  "description": "Combined graph artifact for THSI Static Scientific Evidence Graph v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "graph_id",
    "version",
    "created_at",
    "nodes",
    "edges",
    "sources",
    "validation_summary"
  ],
  "properties": {
    "graph_id": {
      "type": "string",
      "const": "thsi_static_scientific_evidence_graph_v0_1"
    },
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when the graph artifact was built."
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "static_node.schema.json"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "static_edge.schema.json"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "evidence_source.schema.json"
      }
    },
    "validation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_count",
        "node_count",
        "edge_count",
        "direct_diagnostic_edges",
        "validation_status"
      ],
      "properties": {
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "direct_diagnostic_edges": {
          "type": "integer",
          "minimum": 0
        },
        "validation_status": {
          "type": "string",
          "enum": ["passed", "failed"]
        }
      }
    }
  }
}
